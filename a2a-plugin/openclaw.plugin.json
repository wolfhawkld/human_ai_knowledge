{
  "id": "a2a",
  "name": "A2A",
  "description": "Agent-to-Agent communication plugin for OpenClaw. Enables peer-to-peer chat and file sharing between OpenClaw instances over LAN.",
  "version": "0.1.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable A2A functionality"
      },
      "self": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "This agent's unique identifier (e.g., 'nemo', 'outis')"
          },
          "name": {
            "type": "string",
            "description": "Display name for this agent"
          },
          "host": {
            "type": "string",
            "description": "This agent's host IP or hostname"
          },
          "port": {
            "type": "number",
            "default": 18789,
            "description": "Gateway port"
          }
        },
        "default": {},
        "description": "This agent's own identity info for a2a_info"
      },
      "peers": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "host"],
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique peer identifier (e.g., 'nemo')"
            },
            "name": {
              "type": "string",
              "description": "Display name for the peer"
            },
            "host": {
              "type": "string",
              "description": "Hostname or IP address"
            },
            "port": {
              "type": "number",
              "default": 18789,
              "description": "Gateway port"
            },
            "token": {
              "type": "string",
              "description": "Gateway token for authentication"
            }
          }
        },
        "default": [],
        "description": "List of peer OpenClaw agents"
      },
      "fileShare": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable file sharing API"
          },
          "basePath": {
            "type": "string",
            "default": "~/.openclaw/a2a-share",
            "description": "Directory to share with peers"
          },
          "readOnly": {
            "type": "boolean",
            "default": false,
            "description": "If true, only allow read operations"
          }
        },
        "default": {
          "enabled": true,
          "basePath": "~/.openclaw/a2a-share",
          "readOnly": false
        }
      }
    }
  }
}